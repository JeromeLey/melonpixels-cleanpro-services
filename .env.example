# Client Inquiry Automation - Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# NOTION INTEGRATION
# ===========================================
# Get your API key from https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx

# The database ID where leads should be created
# Found in the Notion database URL: notion.so/{workspace}/{DATABASE_ID}
NOTION_LEADS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# EMAIL INTEGRATION
# ===========================================
# Email provider: "sendgrid", "mailgun", or "console" (logs only)
EMAIL_PROVIDER=console

# SendGrid configuration (if EMAIL_PROVIDER=sendgrid)
# Get API key from https://app.sendgrid.com/settings/api_keys
EMAIL_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Mailgun configuration (if EMAIL_PROVIDER=mailgun)
# Get API key from https://app.mailgun.com/app/api-keys
# Also set MAILGUN_DOMAIN to your domain (e.g., mg.melonpixels.com)
# MAILGUN_DOMAIN=mg.melonpixels.com

# Email sender configuration
EMAIL_FROM=noreply@melonpixels.com
EMAIL_FROM_NAME=MelonPixels

# ===========================================
# NOTION DATABASE SETUP
# ===========================================
# Create a Notion database for leads with these properties:
# - Name (title)
# - Email (email)
# - Phone (phone_number)
# - Company (rich_text)
# - Message (rich_text)
# - Source (select) - options: Website, Referral, Social, Other
# - Submitted At (date)
# - Status (select) - options: New, Contacted, Qualified, Proposal, Won, Lost
